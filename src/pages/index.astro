---
import Layout from '../layouts/Layout.astro';
---
<Layout title="FLIGHTGEAR POLSKA - DARMOWY SYMULATOR LOTU | Oficjalny Hub" description="FLIGHTGEAR POLSKA - Darmowy symulator lotu. JSBSim, Nasal, MP Server Map, Quick Start Pack. Pobierz FlightGear za darmo.">
  
  <header class="w-full bg-[#050505] border-b-4 border-cyan-500 py-6">
    <div class="container mx-auto px-6 flex flex-col md:flex-row justify-between items-center gap-6">
      <div class="text-3xl font-black tracking-widest text-white uppercase flex items-center gap-4">
        <!-- Prawa autorskie / Brand Identity -->
        <img src="/assets/logo.png" alt="FLIGHTGEAR POLSKA - Logotyp darmowego symulatora" class="h-10 object-contain" />
        FLIGHTGEAR <span class="text-cyan-500">POLSKA</span>
      </div>
      <nav class="flex gap-6 text-sm font-bold text-gray-500 uppercase tracking-widest">
        <a href="https://github.com/flightgear-polska" target="_blank" class="hover:text-cyan-500 transition-colors" title="Kod Źródłowy FLIGHTGEAR POLSKA (GitHub)">GitHub</a>
        <a href="https://discord.gg/" target="_blank" class="hover:text-cyan-500 transition-colors" title="Skrzydło FLIGHTGEAR POLSKA (Discord)">Discord</a>
        <a href="https://wiki.flightgear.org/" target="_blank" class="hover:text-cyan-500 transition-colors" title="Dokumentacja FLIGHTGEAR POLSKA (Wiki)">Wiki</a>
      </nav>
    </div>
  </header>

  <main class="bg-[#0a0a0a] text-white min-h-screen py-16 font-mono">
    
    <div class="container mx-auto px-6">
      
      <!-- MASSIVE HEADER -->
      <section class="mb-24 text-center md:text-left border-l-8 border-cyan-500 pl-6 py-4 bg-black/50">
        <h1 class="text-4xl md:text-6xl lg:text-7xl font-black uppercase text-white mb-4 tracking-tighter">
          FLIGHTGEAR POLSKA<br/>
          <span class="text-gray-500 block text-2xl md:text-5xl mt-2 tracking-widest drop-shadow-md">- DARMOWY SYMULATOR LOTU</span>
        </h1>
        <p class="text-lg md:text-xl text-cyan-400 font-bold tracking-widest uppercase">
          SYSTEMS ONLINE. NO ARCADE PHYSICS. HIGH-UTILITY AGGREGATOR.
        </p>
      </section>

      <!-- TOOLBOX GRID -->
      <section class="mb-24">
        <h2 class="text-2xl font-black uppercase text-cyan-500 border-b-2 border-gray-800 pb-4 mb-8">:: OPERATIONS TOOLBOX</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          
          <a href="https://www.flightgear.org/download/" target="_blank" title="Pobierz FLIGHTGEAR POLSKA Quick Start Pack" class="group block p-8 bg-[#050505] border-2 border-cyan-600 hover:bg-cyan-600 hover:text-black transition-all shadow-[0_0_15px_rgba(6,182,212,0.15)]">
            <h3 class="text-2xl font-black uppercase mb-4 group-hover:text-black text-cyan-500">[ QUICK START PACK ]</h3>
            <p class="text-sm font-bold text-gray-400 group-hover:text-black leading-relaxed">Najnowsza stabilna wersja silnika (Win/Mac/Lin). Pakiet zawiera domyślne mapy wysokościowe oraz bazę samolotów JSBSim.</p>
          </a>

          <a href="https://mpmap02.flightgear.org/" target="_blank" title="FLIGHTGEAR POLSKA MP Server Map" class="group block p-8 bg-[#050505] border-2 border-gray-800 hover:border-white transition-all">
            <h3 class="text-2xl font-black uppercase mb-4 text-white">[ MP SERVER MAP ]</h3>
            <p class="text-sm font-bold text-gray-500 group-hover:text-gray-300 leading-relaxed">Zintegrowany Tracking Live VFR. Weryfikuj ruch sieciowy nad Polską bezpośrednio w infrastrukturze Multiplayer.</p>
          </a>

          <a href="https://wiki.flightgear.org/" target="_blank" title="FLIGHTGEAR POLSKA Technical Stack Wiki" class="group block p-8 bg-[#050505] border-2 border-gray-800 hover:border-white transition-all">
            <h3 class="text-2xl font-black uppercase mb-4 text-white">[ TECHNICAL WIKI ]</h3>
            <p class="text-sm font-bold text-gray-500 group-hover:text-gray-300 leading-relaxed">Dokumentacja developerska: Nasal Scripting, modele FDM (JSBSim/YASim) Canvas API i integracja kontrolerów (XML).</p>
          </a>

        </div>
      </section>

      <!-- LATEST COMMITS FEED -->
      <section class="mb-24">
        <h2 class="text-2xl font-black uppercase text-cyan-500 border-b-2 border-gray-800 pb-4 mb-6 flex justify-between items-center">
          <span>:: LATEST REPOSITORY COMMITS</span>
          <span class="text-xs bg-cyan-600 text-black px-3 py-1 font-black animate-pulse rounded-sm">API SYNC</span>
        </h2>
        
        <div class="bg-[#050505] border border-gray-800 p-0 overflow-x-auto rounded-sm">
          <table class="w-full text-left text-sm whitespace-nowrap table-auto">
            <thead class="text-gray-600 border-b border-gray-800 bg-[#020202]">
              <tr>
                <th class="p-6">TAG / DATA (UTC)</th>
                <th class="p-6">AUTOR COMMITA</th>
                <th class="p-6">STRUKTURA LOGICZNA</th>
                <th class="p-6">BLOB SHA</th>
              </tr>
            </thead>
            <tbody id="commits-feed" class="text-gray-400">
              <tr>
                <td colspan="4" class="p-8 text-center text-gray-600 font-bold italic animate-pulse">Nawiązywanie połączenia z GitHub API...</td>
              </tr>
            </tbody>
          </table>
        </div>
      </section>

    </div>
  </main>

  <footer class="bg-[#050505] border-t-2 border-cyan-900 py-12 font-mono">
    <div class="container mx-auto px-6 flex flex-col md:flex-row justify-between items-center gap-4">
      <div class="text-gray-600 text-xs font-bold tracking-widest uppercase">
        &copy; FLIGHTGEAR POLSKA TEAM | FIZYKA LOTU & OPEN SOURCE | 2026
      </div>
      <div class="text-gray-600 text-xs font-bold tracking-widest uppercase">
        SYSTEM STATUS: <span class="text-green-500">OPERATIONAL</span>
      </div>
    </div>
  </footer>

  <script>
    // GitHub API Live Fetch Pipeline
    const fetchCommits = async () => {
      try {
        const repo = 'flightgear-polska/flightgear-polska.github.io';
        // Wyciągamy ostatnie 6 commitów technicznych
        const response = await fetch(`https://api.github.com/repos/${repo}/commits?per_page=6`);
        if (!response.ok) throw new Error('API Rate Limit Exceeded');
        const commits = await response.json();
        
        const feed = document.getElementById('commits-feed');
        feed.innerHTML = '';
        
        commits.forEach((c: any) => {
          const date = new Date(c.commit.author.date).toLocaleString('pl-PL', { dateStyle: 'short', timeStyle: 'short'});
          const sha = c.sha.substring(0, 7);
          // Separacja typu commita jeżeli użyto Conventional Commits (np. feat:, fix:, docs:)
          const msgArray = c.commit.message.split('\n')[0].split(':');
          const type = msgArray.length > 1 ? msgArray[0] + ':' : 'commit:';
          const content = msgArray.length > 1 ? msgArray.slice(1).join(':') : msgArray[0];

          const row = `
            <tr class="border-b border-gray-900 hover:bg-gray-800 transition">
              <td class="p-6 text-cyan-600 font-bold tracking-widest">${date}</td>
              <td class="p-6 text-white font-bold">${c.commit.author.name}</td>
              <td class="p-6 text-gray-300 truncate max-w-lg" title="${c.commit.message}">
                <span class="text-gray-500 uppercase tracking-widest text-xs mr-2">${type}</span> ${content}
              </td>
              <td class="p-6"><a href="${c.html_url}" target="_blank" class="text-cyan-600 hover:text-cyan-400 underline font-mono tracking-widest">${sha}</a></td>
            </tr>
          `;
          feed.innerHTML += row;
        });
      } catch (err) {
        document.getElementById('commits-feed').innerHTML = '<tr><td colspan="4" class="p-8 text-center text-red-500 font-bold uppercase tracking-widest">Błąd GitHub API. Spróbuj powrócić za godzinę w przypadku restrykcji RATE_LIMIT.</td></tr>';
      }
    };
    
    // Inicjacja przy załadowaniu DOM
    fetchCommits();
  </script>
</Layout>
