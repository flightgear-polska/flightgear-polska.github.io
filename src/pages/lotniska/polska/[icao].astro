---
import Layout from '../../../layouts/Layout.astro';
import { parse } from 'csv-parse/sync';

export async function getStaticPaths() {
  const response = await fetch('https://raw.githubusercontent.com/davidmegginson/ourairports-data/main/airports.csv');
  const csvData = await response.text();
  
  const records = parse(csvData, {
    columns: true,
    skip_empty_lines: true
  });

  const lotniskaPL = records.filter(
    (lot: any) => lot.iso_country === 'PL' && lot.type !== 'closed' && lot.ident.length === 4
  );

  return lotniskaPL.map((l: any) => ({
    params: { icao: l.ident.toLowerCase() },
    props: { 
      miasto: l.municipality || 'Polska', 
      kod: l.ident, 
      nazwa: l.name, 
      wspolrzedne: `${l.latitude_deg}, ${l.longitude_deg}` 
    }
  }));
}

const { miasto, kod, nazwa, wspolrzedne } = Astro.props;
---
<Layout title={`Symulator Lotu ${miasto} | Ląduj na ${nazwa} (${kod.toUpperCase()}) Darmowa Gra`}>
  <script type="application/ld+json" set:html={`
    {
       "@context": "https://schema.org",
       "@type": "Place",
       "name": "${nazwa}",
       "geo": {
         "@type": "GeoCoordinates",
         "latitude": "${wspolrzedne.split(',')[0]}",
         "longitude": "${wspolrzedne.split(',')[1]}"
       }
    }
  `} />

  <header class="bg-dark-800 border-b border-white/5 py-20 relative overflow-hidden">
    <div class="absolute top-0 right-0 w-1/2 h-full bg-brand-500/10 blur-[100px]"></div>
    <div class="container mx-auto px-6 relative z-10">
      <a href="/" class="text-brand-500 hover:text-white transition text-sm mb-4 inline-block">&larr; Powrót na główną</a>
      <h1 class="text-4xl lg:text-5xl font-heading font-bold text-white mb-4">
        Lotnisko <span class="text-brand-400">{nazwa}</span> ({kod.toUpperCase()})
      </h1>
      <p class="text-xl text-gray-400">Pobierz darmowy symulator i wystartuj z miasta {miasto}.</p>
    </div>
  </header>

  <main class="container mx-auto px-6 py-16">
    <div class="bg-white/5 border border-white/10 rounded-2xl p-8 max-w-2xl">
      <h2 class="text-2xl font-bold mb-6">Dane nawigacyjne do GPS / FMC</h2>
      <ul class="space-y-4 text-gray-300">
        <li class="flex justify-between border-b border-white/5 pb-2">
          <span>Kod ICAO</span> <span class="font-mono text-white">{kod.toUpperCase()}</span>
        </li>
        <li class="flex justify-between border-b border-white/5 pb-2">
          <span>Współrzędne</span> <span class="font-mono text-white">{wspolrzedne}</span>
        </li>
        <li class="flex justify-between border-b border-white/5 pb-2">
          <span>Miasto</span> <span class="text-white">{miasto}</span>
        </li>
      </ul>
      
      <div class="mt-8">
        <a href="https://www.flightgear.org/download/" target="_blank" rel="noopener noreferrer" class="block w-full py-3 bg-brand-500 hover:bg-brand-600 text-white text-center font-bold rounded-lg transition shadow-[0_0_15px_rgba(20,184,166,0.3)]">
          Pobierz symulator z tą scenerią
        </a>
      </div>
    </div>
  </main>
</Layout>
