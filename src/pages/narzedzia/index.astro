---
import Layout from '../../layouts/Layout.astro';
import LiveMap from '../../components/LiveMap.astro';
import ConfigGenerator from '../../components/ConfigGenerator.astro';
import LogbookForm from '../../components/LogbookForm.astro';
---
<Layout title="Narzędzia Pilota VFR | FlightGear Polska">
  <header class="bg-dark-900 border-b border-white/5 pt-32 pb-12 relative overflow-hidden">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-3/4 h-full bg-brand-500/10 blur-[120px]"></div>
    <div class="container mx-auto px-6 relative z-10 text-center">
      <h1 class="text-4xl lg:text-5xl font-heading font-black text-white mb-6">
        Interaktywny <span class="text-brand-500">Hub Pilota</span>
      </h1>
      <p class="text-lg text-gray-400 max-w-2xl mx-auto">Zaawansowane narzędzia dla wirtualnych lotników operujące bezpośrednio z silnika Twojej przeglądarki. Zero lania wody.</p>
      
      <div class="mt-8 flex justify-center flex-wrap gap-4 text-sm font-medium">
         <a href="#radar" class="px-6 py-3 rounded border border-white/10 hover:bg-white/5 text-white transition">Radar Live</a>
         <a href="#config" class="px-6 py-3 rounded border border-white/10 hover:bg-white/5 text-white transition">Generator XML</a>
         <a href="#logbook" class="px-6 py-3 rounded border border-white/10 hover:bg-white/5 text-white transition">Dziennik Pokładowy (Git DB)</a>
      </div>
    </div>
  </header>

  <main class="container mx-auto px-6 py-16 space-y-16">
    
    <section id="radar" class="scroll-mt-32 w-full max-w-6xl mx-auto">
       <LiveMap />
    </section>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 w-full max-w-6xl mx-auto">
      <section id="config" class="scroll-mt-32">
         <ConfigGenerator />
      </section>

      <section id="logbook" class="scroll-mt-32">
         <LogbookForm />
      </section>
    </div>

  </main>
</Layout>
