<div class="bg-gray-100 p-8 rounded-xl border border-gray-300 text-dark-900 shadow-xl relative overflow-hidden">
  <div class="absolute right-0 top-0 text-gray-200 opacity-20 pointer-events-none">
     <svg class="w-48 h-48" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
  </div>

  <h2 class="text-3xl font-bold mb-2 font-heading relative z-10">Rejestr Lotów <span class="text-blue-600">(GitHub Backend)</span></h2>
  <p class="text-gray-600 mb-8 text-sm relative z-10">Logi są podbijane rykoszetem przez otwarte API Issues bezpośrednio na repozytorium GitHub i przepuszczane przez Actions do bazy danych. Brak ukrytego backendu.</p>
  
  <form id="logbook-form" class="space-y-6 relative z-10">
    <div class="flex gap-4">
      <div class="flex-1">
        <label class="block text-sm mb-2 text-gray-700 font-bold">Znak wywoławczy (Callsign)</label>
        <input type="text" id="pilot-id" placeholder="SP-NTX" class="bg-white border border-gray-300 rounded-lg p-3 w-full text-black focus:outline-none focus:border-blue-500" required />
      </div>
      <div class="flex-1">
        <label class="block text-sm mb-2 text-gray-700 font-bold">Destynacja ICAO</label>
        <input type="text" id="route" placeholder="EPWA - EPKK" class="bg-white border border-gray-300 rounded-lg p-3 w-full text-black focus:outline-none focus:border-blue-500" required />
      </div>
    </div>

    <button type="submit" class="bg-dark-900 hover:bg-black text-white font-bold py-4 px-6 rounded-lg w-full transition shadow-lg">
      Autoryzuj i Wypchnij Raport (Przekierowanie)
    </button>
  </form>
</div>

<script>
  document.getElementById('logbook-form').addEventListener('submit', (e) => {
    e.preventDefault();
    const pilot = document.getElementById('pilot-id').value;
    const route = document.getElementById('route').value;
    
    // Twarde kodowanie formatki do Issue, co gwarantuje spójność parsowania Regexem w GitHub Actions.
    const body = `### Flight Report
**Pilot:** ${pilot}
**Trasa:** ${route}
**Moduł:** VFR Poland
**Timestamp:** ${new Date().toISOString().split('T')[0]}`;
    
    // Zero-Footprint Backend: używamy natywnego routingu Githuba do stworzenia pre-filled ticketu, do ominięcia problemu CORS/PAT.
    const repo = 'flightgear-polska/flightgear-polska.github.io';
    const url = `https://github.com/${repo}/issues/new?title=LOG:%20${encodeURIComponent(pilot)}&body=${encodeURIComponent(body)}&labels=logbook`;
    
    window.location.href = url; // Hard redirect
  });
</script>
